rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /canvases/{canvasId} {
      // Any signed-in user can read any canvas (for shared links)
      allow read: if request.auth != null;

      // Only the owner can create (userId must match their UID)
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Any signed-in user can update (needed for real-time collaboration)
      allow update: if request.auth != null;

      // Only the owner can delete
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;

      // Presence sub-collection: any signed-in user can read;
      // users can only write their own presence document
      match /presence/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Comments sub-collection: any signed-in user can read;
      // any signed-in user can add a comment; only comment author can update
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null
                      && resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null
                      && resource.data.uid == request.auth.uid;
      }
    }
  }
}
